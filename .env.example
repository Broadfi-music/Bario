# Copy this file to .env.local for local development and replace placeholder values.
# In production/cloud, set the same keys as platform environment variables instead.

# Backend/runtime
REMIX_DEVICE=cuda
DEMUCS_SEGMENT_SECONDS=7
REMIX_ALLOW_MOCK_FALLBACK=0
REMIX_TARGET_DURATION=20
REMIX_LONG_SOURCE_TRIGGER_SECONDS=75
REMIX_MAX_PROCESSING_SOURCE_SECONDS=45

# Active cloud pipeline for this setup: Replicate Demucs + sakemin/musicgen-remixer.
REMIX_SEPARATOR_PROVIDER=replicate
REMIX_GENERATOR_PROVIDER=replicate

# Local MusicGen settings are ignored while REMIX_GENERATOR_PROVIDER=replicate.
# Uncomment these only if you switch back to local generation.
# MUSICGEN_MODEL=facebook/musicgen-melody
# MUSICGEN_LOCAL_ONLY=0
# MUSICGEN_CACHE_DIR=D:\hf-cache

REPLICATE_DEMUCS_MODEL=cjwbw/demucs:25a173108cff36ef9f80f854c162d01df9e6528be175794b81158fa03836d953
REPLICATE_DEMUCS_MODEL_NAME=htdemucs_ft
REPLICATE_DEMUCS_SHIFTS=1
REPLICATE_DEMUCS_OVERLAP=0.25
REPLICATE_DEMUCS_OUTPUT_FORMAT=wav
REPLICATE_REQUEST_TIMEOUT_SECONDS=300
REPLICATE_DOWNLOAD_TIMEOUT_SECONDS=300
REPLICATE_RETRY_COUNT=3
REPLICATE_RETRY_BACKOFF_SECONDS=2.0

# Replicate settings
REPLICATE_API_TOKEN=r8_replace_with_your_real_token
REPLICATE_MODEL=sakemin/musicgen-remixer:e89b6e5f6e2acf5fd95ee0475799b8dd527109195e201d9dca8a9de95551d035
REPLICATE_MODEL_VERSION=stereo-chord
REPLICATE_AUDIO_INPUT_NAME=music_input
REPLICATE_ATTACH_AUDIO=1
REPLICATE_OUTPUT_FORMAT=wav
REPLICATE_TOP_K=250
REPLICATE_TOP_P=0
REPLICATE_TEMPERATURE=1
REPLICATE_CONTINUATION=0
REPLICATE_CONTINUATION_START=0
REPLICATE_MULTI_BAND_DIFFUSION=0
REPLICATE_NORMALIZATION_STRATEGY=peak
REPLICATE_CLASSIFIER_FREE_GUIDANCE=3
REPLICATE_BEAT_SYNC_THRESHOLD=0.75
REPLICATE_LARGE_CHORD_VOCA=1
REPLICATE_CHROMA_COEFFICIENT=1
REPLICATE_SEED=-1
